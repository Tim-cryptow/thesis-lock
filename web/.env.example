NEXT_PUBLIC_CONTRACT_ADDRESS=SP3QS6X01XKTYC84BHA0J567CZTAH67BJHN88FNVM
NEXT_PUBLIC_CONTRACT_NAME=thesislock
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_API_URL=https://api.mainnet.hiro.so
# Absolute site URL used for Open Graph and Twitter card metadata.
# On Vercel this falls back to the production deployment URL automatically.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Browser-safe Supabase reads. The app's feed, stats, profile, search, and verify
# read paths query the thesis_locks index with the public anon key (and the
# public-read RLS policy), falling back to the Hiro API when these are unset.
# Distinct from the server-only SUPABASE_* write vars below.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets for the Hiro Chainhook event sync. These are NOT prefixed
# NEXT_PUBLIC_, so they are never exposed to the browser. Set them in Vercel.
# Shared secret the chainhook must present, either as an
# "Authorization: Bearer <token>" header or a "?token=<token>" query parameter.
CHAINHOOK_AUTH_TOKEN=
# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Supabase service-role key (server-side writes; bypasses RLS). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
